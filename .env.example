ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Optional: enables semantic search via pgvector + OpenAI embeddings.
# Without this, /memories/search falls back to keyword (substring) scan.
OPENAI_API_KEY=your-openai-api-key-here

DATABASE_URL=postgres://memorywiki:memorywiki@localhost:5432/memorywiki?sslmode=disable

MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=memories
MINIO_USE_SSL=false

PORT=8080
